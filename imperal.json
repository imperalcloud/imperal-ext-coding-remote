{
  "manifest_schema_version": 3,
  "sdk_version": "5.9.12",
  "app_id": "coding-remote",
  "version": "1.2.2",
  "name": "Coding Remote",
  "description": "Control your terminal Webbee Code session remotely — mirror it to Telegram or the panel and steer it back.",
  "icon": "icon.svg",
  "actions_explicit": true,
  "system": true,
  "capabilities": [
    "coding_remote:read",
    "coding_remote:write"
  ],
  "tools": [
    {
      "name": "get_status",
      "description": "Show remote-control status of the terminal coding session (active? mirror/steer routing).",
      "action_type": "read",
      "chain_callable": true,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "description": "No parameters needed.",
        "properties": {},
        "title": "EmptyParams",
        "type": "object"
      },
      "return_schema": {
        "description": "Remote-control status of the terminal Webbee Code session.\n\nactive/session_id describe whether a coding session is currently live;\nenabled/mirror/steer are the effective routing state (mirror = where\nsession output is echoed, steer = where replies can drive it back).\n\n``checked_at`` is the UTC ISO-8601 timestamp of the moment THIS answer\nwas fetched from the gateway (set by fn_status only) — the gateway's\n``GET /v1/internal/coding-remote/{uid}`` has no session last-activity\ntimestamp today, so this is an honest \"as-of\" freshness marker, never a\nfabricated \"last seen\" for the terminal itself. write-tools (fn_set/\nfn_send/fn_stop/fn_coding_mode) leave it unset — their echoed ``active``\nis a point-in-time write acknowledgement, not a fresh status read; the\npanel always re-fetches via fn_status after any write (see panels.py).",
        "properties": {
          "id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "integer"
              }
            ],
            "title": "Id"
